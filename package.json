{
  "name": "kanon",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Marc Dechand",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kanon/api dev",
    "build": "pnpm --filter @kanon/api build",
    "db:generate": "pnpm --filter @kanon/api db:generate",
    "db:migrate": "pnpm --filter @kanon/api db:migrate",
    "db:seed": "pnpm --filter @kanon/api db:seed",
    "db:studio": "pnpm --filter @kanon/api db:studio",
    "smoke-test": "pnpm --filter @kanon/api smoke-test",
    "dev:web": "pnpm --filter @kanon/web dev",
    "build:web": "pnpm --filter @kanon/web build",
    "e2e": "pnpm --filter @kanon/e2e test",
    "e2e:ui": "pnpm --filter @kanon/e2e test:ui",
    "test:all": "pnpm --filter @kanon/api test && pnpm --filter @kanon/web test && pnpm e2e",
    "dev:start": "bash scripts/dev-start.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "setup:mcp": "pnpm --filter @kanon-pm/setup build && node packages/setup/dist/index.js",
    "setup:ai": "pnpm --filter @kanon-pm/setup build && node packages/setup/dist/index.js",
    "setup": "bash scripts/setup.sh",
    "kanon": "pnpm --filter @kanon/cli build && node packages/cli/dist/index.js"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
