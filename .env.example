# ─── Kanon Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kanon

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-min-16-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-min-16-chars

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Ports (used by dev scripts, docker-compose, and setup-mcp) ─────────────
# Override these to run on different ports without editing scripts.
KANON_API_PORT=3000
KANON_WEB_PORT=5173
KANON_API_URL=http://localhost:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcards)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── Engram Integration ─────────────────────────────────────────────────────
# URL of the Engram persistent memory server
ENGRAM_URL=http://localhost:7437

# API key for Engram authentication (optional, only if Engram requires auth)
# ENGRAM_API_KEY=your-engram-api-key

# ─── Kanon API (for CLI usage) ───────────────────────────────────────────────
# API key for authenticating CLI requests to the Kanon API
# KANON_API_KEY=your-kanon-api-key

# URL of the Kanon API (used by the CLI when connecting remotely)
# KANON_API_URL=http://localhost:3000
