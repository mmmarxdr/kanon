generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum IssueType {
  feature
  bug
  task
  spike
}

enum IssuePriority {
  critical
  high
  medium
  low
}

enum IssueState {
  backlog
  todo
  in_progress
  review
  done
}

enum MemberRole {
  owner
  admin
  member
  viewer
}

enum CycleState {
  upcoming
  active
  done
}

enum CycleScopeEventKind {
  add
  remove
}

enum ActivityAction {
  created
  state_changed
  assigned
  commented
  cycle_changed
  edited
  engram_synced
}

enum CommentSource {
  human
  mcp
  engram_sync
  system
}

enum Horizon {
  now
  next
  later
  someday
}

enum RoadmapStatus {
  idea
  planned
  in_progress
  done
}

enum DependencyType {
  blocks
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  apiKeyHash   String?  @map("api_key_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members      Member[]
  workSessions WorkSession[]
  createdInvites WorkspaceInvite[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  allowedDomains String[] @default([]) @map("allowed_domains")

  projects Project[]
  members  Member[]
  invites  WorkspaceInvite[]
  proposals McpProposal[]

  @@map("workspaces")
}

model McpProposal {
  id          String            @id @default(uuid()) @db.Uuid
  kind        McpProposalKind
  status      McpProposalStatus @default(pending)
  title       String
  reason      String?
  /** Optional reference key — issue key, roadmap item id, etc. */
  targetRef   String?           @map("target_ref")
  /** Free-form payload (action description, suggested values). */
  payload     Json?
  /** Identifier of the agent that produced the proposal (e.g. "claude-mcp"). */
  generatedBy String?           @map("generated_by")
  proposedAt  DateTime          @default(now()) @map("proposed_at")
  appliedAt   DateTime?         @map("applied_at")
  dismissedAt DateTime?         @map("dismissed_at")

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  projectId String?  @map("project_id") @db.Uuid
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([projectId, status])
  @@map("mcp_proposals")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @db.VarChar(6)
  name        String
  description String?
  archived         Boolean  @default(false)
  engramNamespace  String?  @map("engram_namespace")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  issues       Issue[]
  cycles       Cycle[]
  roadmapItems RoadmapItem[]
  proposals    McpProposal[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("projects")
}

model Issue {
  id          String        @id @default(uuid()) @db.Uuid
  key         String        @unique
  sequenceNum Int           @map("sequence_num")
  title       String
  description String?
  type        IssueType     @default(task)
  priority    IssuePriority @default(medium)
  state       IssueState    @default(backlog)
  labels      String[]      @default([])
  dueDate     DateTime?     @map("due_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Grouping key for SDD change aggregation (derived from topic_key prefix)
  groupKey    String?       @map("group_key")

  // JSON fields for extensibility
  engramContext Json? @map("engram_context")
  specArtifacts Json? @map("spec_artifacts")

  // Relations
  projectId  String  @map("project_id") @db.Uuid
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String? @map("assignee_id") @db.Uuid
  assignee   Member? @relation("AssignedIssues", fields: [assigneeId], references: [id], onDelete: SetNull)

  /** Story-point estimate. Null = unestimated. Used by Cycles burnup. */
  estimate Int? @map("estimate")

  cycleId String? @map("cycle_id") @db.Uuid
  cycle   Cycle?  @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  parentId String? @map("parent_id") @db.Uuid
  parent   Issue?  @relation("SubIssues", fields: [parentId], references: [id], onDelete: SetNull)
  children Issue[] @relation("SubIssues")

  roadmapItemId String?      @map("roadmap_item_id") @db.Uuid
  roadmapItem   RoadmapItem? @relation(fields: [roadmapItemId], references: [id], onDelete: SetNull)

  activityLogs ActivityLog[]
  comments     Comment[]
  workSessions WorkSession[]

  // Issue→Issue dependencies (semantically distinct from RoadmapDependency)
  blocks    IssueDependency[] @relation("IssueBlocks")
  blockedBy IssueDependency[] @relation("IssueBlockedBy")

  @@unique([projectId, key])
  @@index([projectId, state])
  @@index([projectId, groupKey])
  @@index([cycleId])
  @@index([assigneeId])
  @@index([parentId])
  @@map("issues")
}

enum IssueDependencyType {
  blocks
}

enum McpProposalKind {
  promote_roadmap_item    // Promote a roadmap item to a sooner horizon
  add_dependency          // Suggest a new dependency edge (issue or roadmap)
  split_issue             // Split a single issue into atomic sub-issues
  reassign                // Suggest a different assignee
  generic                 // Anything else; payload describes
}

enum McpProposalStatus {
  pending
  applied
  dismissed
}

model IssueDependency {
  id        String              @id @default(uuid()) @db.Uuid
  type      IssueDependencyType @default(blocks)
  createdAt DateTime            @default(now()) @map("created_at")

  sourceId String @map("source_id") @db.Uuid
  source   Issue  @relation("IssueBlocks", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String @map("target_id") @db.Uuid
  target   Issue  @relation("IssueBlockedBy", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
  @@map("issue_dependencies")
}

model Cycle {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  goal      String?
  state     CycleState @default(upcoming)
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  /** Velocity in story points. Set when the cycle is closed. */
  velocity  Int?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  projectId String  @map("project_id") @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  issues      Issue[]
  scopeEvents CycleScopeEvent[]

  @@index([projectId, state])
  @@index([projectId, startDate])
  @@map("cycles")
}

model CycleScopeEvent {
  id        String              @id @default(uuid()) @db.Uuid
  /** Day index within the cycle (1-based) at the moment of the change. */
  day       Int
  kind      CycleScopeEventKind
  /** Issue key (KAN-123) at the time of the event. Stored as string so the
   *  event survives even if the issue is later deleted. */
  issueKey  String              @map("issue_key")
  reason    String?
  createdAt DateTime            @default(now()) @map("created_at")

  cycleId String @map("cycle_id") @db.Uuid
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  authorId String? @map("author_id") @db.Uuid
  author   Member? @relation("CycleScopeAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([cycleId, day])
  @@map("cycle_scope_events")
}

model Member {
  id        String     @id @default(uuid()) @db.Uuid
  username  String
  role      MemberRole @default(member)
  isAgent   Boolean    @default(false) @map("is_agent")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  assignedIssues   Issue[]           @relation("AssignedIssues")
  activityLogs     ActivityLog[]
  comments         Comment[]
  workSessions     WorkSession[]
  cycleScopeEvents CycleScopeEvent[] @relation("CycleScopeAuthor")

  @@unique([userId, workspaceId])
  @@unique([workspaceId, username])
  @@map("members")
}

model ActivityLog {
  id        String         @id @default(uuid()) @db.Uuid
  action    ActivityAction
  details   Json?
  createdAt DateTime       @default(now()) @map("created_at")

  issueId String @map("issue_id") @db.Uuid
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  memberId String @map("member_id") @db.Uuid
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
  @@map("activity_logs")
}

model Comment {
  id        String        @id @default(uuid()) @db.Uuid
  body      String
  source    CommentSource @default(human)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  issueId String @map("issue_id") @db.Uuid
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  authorId String @map("author_id") @db.Uuid
  author   Member @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
  @@map("comments")
}

model RoadmapItem {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  horizon     Horizon  @default(later)
  effort      Int?
  impact      Int?
  labels      String[] @default([])
  targetDate  DateTime? @map("target_date")
  sortOrder   Float         @default(0) @map("sort_order")
  promoted    Boolean       @default(false)
  status      RoadmapStatus @default(idea)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id") @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  issues Issue[]

  dependencySource RoadmapDependency[] @relation("DependencySource")
  dependencyTarget RoadmapDependency[] @relation("DependencyTarget")

  @@index([projectId, horizon])
  @@map("roadmap_items")
}

model RoadmapDependency {
  id        String         @id @default(uuid()) @db.Uuid
  type      DependencyType @default(blocks)
  createdAt DateTime       @default(now()) @map("created_at")

  sourceId String      @map("source_id") @db.Uuid
  source   RoadmapItem @relation("DependencySource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String      @map("target_id") @db.Uuid
  target   RoadmapItem @relation("DependencyTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([targetId])
  @@map("roadmap_dependencies")
}

model WorkSession {
  id            String    @id @default(uuid()) @db.Uuid
  startedAt     DateTime  @default(now()) @map("started_at")
  lastHeartbeat DateTime  @default(now()) @map("last_heartbeat")
  source        String    @default("mcp") // "mcp" | "web" | "claude-code" | "cursor"

  userId   String @map("user_id") @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  issueId  String @map("issue_id") @db.Uuid
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  memberId String @map("member_id") @db.Uuid
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
  @@index([issueId, lastHeartbeat])
  @@index([memberId, lastHeartbeat])
  @@map("work_sessions")
}

model WorkspaceInvite {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  role      String    @default("member")
  maxUses   Int       @default(0) @map("max_uses")   // 0 = unlimited
  useCount  Int       @default(0) @map("use_count")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  label     String?                                   // optional description
  email     String?   @map("email")                   // optional recipient email
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdById String @map("created_by_id") @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([token])
  @@map("workspace_invites")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}
