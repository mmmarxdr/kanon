# ── Database (required) ────────────────────────────────────────
DATABASE_URL="postgresql://kanon:kanon@localhost:5432/kanon?schema=public"

# ── Auth (required) ───────────────────────────────────────────
JWT_SECRET="dev-jwt-secret-change-in-production"        # Min 16 chars
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-in-production"  # Min 16 chars
COOKIE_SECRET=                    # Optional. Random string for cookie signing.

# ── Server ────────────────────────────────────────────────────
PORT=3000                         # Optional. Default: 3000
NODE_ENV=development              # Optional. development | production | test
CORS_ORIGIN=http://localhost:5173 # Optional. Comma-separated URLs

# ── Engram (optional) ────────────────────────────────────────
ENGRAM_URL=http://localhost:7437   # Engram API base URL. Default: http://localhost:7437
ENGRAM_API_KEY=                    # Optional. Bearer token for Engram auth.
ENGRAM_SYNC_ENABLED=false          # Set to "true" to enable bridge sync. Default: false
ENGRAM_POLL_INTERVAL_MS=15000      # Min 5000. Polling interval for sync. Default: 15000
