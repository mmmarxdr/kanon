{
  "name": "@kanon-pm/setup",
  "version": "0.5.0",
  "type": "module",
  "description": "Setup and configure Kanon AI tool integrations (Claude Code, Cursor, Antigravity)",
  "bin": {
    "kanon-setup": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "bash scripts/copy-assets.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify-assets": "bash scripts/verify-assets.sh",
    "prepublishOnly": "pnpm build && bash scripts/verify-assets.sh"
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
