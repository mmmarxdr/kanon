# Kanon Production Environment
# Copy to .env.production and fill in all CHANGE_ME values.

# --- Required ---

# PostgreSQL credentials (must match DATABASE_URL)
POSTGRES_PASSWORD=CHANGE_ME

# Full connection string (password must match POSTGRES_PASSWORD)
DATABASE_URL=postgresql://kanon:CHANGE_ME@postgres:5432/kanon?schema=public

# JWT secrets — minimum 32 characters, must be unique random strings
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS

# Your production URL (used for CORS). Comma-separated for multiple origins.
CORS_ORIGIN=https://your-domain.com

# --- Optional ---

# Cookie signing secret (recommended for production)
# COOKIE_SECRET=CHANGE_ME

# Ports (defaults shown)
# KANON_WEB_PORT=80

# Engram memory service (enable with: --profile engram)
# ENGRAM_SYNC_ENABLED=false
